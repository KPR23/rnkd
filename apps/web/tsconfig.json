{
	"extends": "@repo/typescript-config/nextjs.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"],
			"@repo/ui/*": ["../../packages/ui/components/ui/*"]
		},
		"plugins": [
			{
				"name": "next"
			}
		],
		"strictNullChecks": true,
		"strict": true
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"next-env.d.ts",
		"next.config.js",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
